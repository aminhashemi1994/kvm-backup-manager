# Agent Backend Configuration
NODE_ENV=development
PORT=3001

# Service IP - Set to 0.0.0.0 for all interfaces, 127.0.0.1 for localhost only
SERVICE_IP=0.0.0.0

# Controller URL (for callbacks and WebSocket)
# IMPORTANT: The agent will automatically discover its identity from the controller
# based on the port number. Make sure this agent is registered in the controller.
CONTROLLER_URL=http://localhost:3000

# JWT Authentication for Agent
# 1. AGENT_JWT_TOKEN: Static token for agent -> controller calls (fetching storage pools, etc.)
#    IMPORTANT: Must match AGENT_STATIC_TOKEN in controller .env
#    Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AGENT_JWT_TOKEN=agent-static-token-change-this-in-production-use-long-random-string

# 2. AGENT_JWT_SECRET: Secret for controller -> agent calls (triggering backups, etc.)
#    IMPORTANT: Must match AGENT_JWT_SECRET in controller .env
#    Generate with: openssl rand -base64 32
AGENT_JWT_SECRET=agent-secret-key-change-in-production-use-openssl-rand-base64-32

# SSH Configuration
SSH_TIMEOUT=30000
SSH_READY_TIMEOUT=20000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Concurrent Backups
MAX_CONCURRENT_BACKUPS=2
