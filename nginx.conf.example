# Nginx reverse proxy configuration for KVM Backup Manager

# Upstream definitions for better load balancing and health checks
upstream controller_backend {
    server localhost:3000 fail_timeout=30s max_fails=3;
    keepalive 32;
}

upstream controller_frontend {
    server localhost:5173 fail_timeout=30s max_fails=3;
    keepalive 32;
}

upstream agent_backend {
    server localhost:3001 fail_timeout=30s max_fails=3;
    keepalive 32;
}

# Controller (Main Management Interface)
server {
    listen 80;
    server_name controller.example.com;

    # Increase client body size for large file uploads (if needed)
    client_max_body_size 100M;
    
    # Timeouts for long-running operations
    proxy_connect_timeout 60s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;
    
    # Buffer settings for better performance
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 8 4k;
    proxy_busy_buffers_size 8k;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Frontend
    location / {
        proxy_pass http://controller_frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Enable keepalive
        proxy_set_header Connection "";
    }

    # Controller Backend API
    location /api {
        proxy_pass http://controller_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Longer timeout for report generation and long operations
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
        
        # Enable keepalive
        proxy_set_header Connection "";
    }

    # Socket.io WebSocket for real-time updates
    location /socket.io {
        proxy_pass http://controller_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # WebSocket specific timeouts
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
    
    # Health check endpoint (optional)
    location /health {
        proxy_pass http://controller_backend/api/health;
        access_log off;
    }
}

# Agent (runs on each backup host)
# This configuration goes on the backup host servers
server {
    listen 80;
    server_name agent.backup-host.example.com;

    # Increase client body size for SSH key uploads
    client_max_body_size 10M;
    
    # Timeouts for long-running backup/restore operations
    proxy_connect_timeout 60s;
    proxy_send_timeout 600s;
    proxy_read_timeout 600s;
    
    # Buffer settings
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 8 4k;
    proxy_busy_buffers_size 8k;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Agent API
    location / {
        proxy_pass http://agent_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Enable keepalive
        proxy_set_header Connection "";
    }

    # WebSocket for streaming logs
    location /socket.io {
        proxy_pass http://agent_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # WebSocket specific timeouts
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
    
    # Health check endpoint (optional)
    location /health {
        proxy_pass http://agent_backend/api/health;
        access_log off;
    }
}

# SSL/TLS Configuration Example (Recommended for Production)
# Uncomment and configure for HTTPS
#
# server {
#     listen 443 ssl http2;
#     server_name controller.example.com;
#
#     # SSL Certificate
#     ssl_certificate /etc/ssl/certs/controller.crt;
#     ssl_certificate_key /etc/ssl/private/controller.key;
#
#     # SSL Configuration
#     ssl_protocols TLSv1.2 TLSv1.3;
#     ssl_ciphers HIGH:!aNULL:!MD5;
#     ssl_prefer_server_ciphers on;
#     ssl_session_cache shared:SSL:10m;
#     ssl_session_timeout 10m;
#
#     # HSTS (optional but recommended)
#     add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
#
#     # ... rest of configuration same as HTTP version ...
# }
#
# # Redirect HTTP to HTTPS
# server {
#     listen 80;
#     server_name controller.example.com;
#     return 301 https://$server_name$request_uri;
# }

# Rate Limiting Configuration (Optional but Recommended)
# Add this to http block in main nginx.conf
#
# limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
# limit_req_zone $binary_remote_addr zone=report_limit:10m rate=1r/m;
#
# Then add to location blocks:
# location /api/reports/generate {
#     limit_req zone=report_limit burst=2 nodelay;
#     # ... rest of config ...
# }
#
# location /api {
#     limit_req zone=api_limit burst=20 nodelay;
#     # ... rest of config ...
# }
