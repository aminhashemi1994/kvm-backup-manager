# Controller Backend Configuration
NODE_ENV=development
PORT=3000

# Service IP - Set to 0.0.0.0 for all interfaces, 127.0.0.1 for localhost only
SERVICE_IP=0.0.0.0

# CORS is always set to allow all origins (*) - no configuration needed

# Data Directory
DATA_DIR=./data

# Logging
LOG_LEVEL=info

# JWT Authentication
# Secret key for user authentication (frontend -> controller)
# IMPORTANT: Change this in production! Use a strong random string
JWT_SECRET=your-secret-key-change-in-production-use-openssl-rand-base64-32

# JWT token expiration time (default: 24h)
# Examples: 60s, 5m, 1h, 7d
JWT_EXPIRES_IN=24h

# Static token for agent authentication (agent -> controller)
# IMPORTANT: This MUST match AGENT_JWT_TOKEN in agent backend .env
# This is a simple static token for agent callbacks to controller
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AGENT_STATIC_TOKEN=agent-static-token-change-this-in-production-use-long-random-string

# Secret key for agent authentication (controller -> agent)
# IMPORTANT: Change this in production! Use a strong random string
# This should be different from JWT_SECRET
AGENT_JWT_SECRET=agent-secret-key-change-in-production-use-openssl-rand-base64-32

# Agent Configuration
AGENT_REQUEST_TIMEOUT=300000
AGENT_HEALTH_CHECK_INTERVAL=60000

# Scheduler
MAX_CONCURRENT_BACKUPS=20

# Rocket.Chat Integration
# Two methods are supported:
# 1. Webhook (simpler, recommended): Only requires ROCKETCHAT_WEBHOOK_URL
# 2. API (advanced): Requires URL, AUTH_TOKEN, USER_ID, and CHANNEL
ROCKETCHAT_ENABLED=false

# Method 1: Webhook URL (recommended)
# Get this from: Administration -> Integrations -> New Integration -> Incoming WebHook
# Example: https://chat.domain.com/hooks/XXXXXXX/NPWNBmMNhYwck2bwaJkBXd4FM7NiHXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ROCKETCHAT_WEBHOOK_URL=

# Method 2: API (optional, only if not using webhook)
ROCKETCHAT_URL=https://chat.example.com
ROCKETCHAT_AUTH_TOKEN=your_auth_token_here
ROCKETCHAT_USER_ID=your_user_id_here
ROCKETCHAT_CHANNEL=backup-notifications

# SSL/TLS Configuration
# Enable HTTPS and WSS (WebSocket Secure)
SSL_ENABLED=false
# Path to SSL certificate file
SSL_CERT_PATH=/path/to/certificate.crt
# Path to SSL private key file
SSL_KEY_PATH=/path/to/privateKey.pem
