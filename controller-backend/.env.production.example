# Controller Backend - Production Configuration with SSL

NODE_ENV=production
PORT=3000
SERVICE_IP=0.0.0.0

# Data Directory
DATA_DIR=./data

# Logging
LOG_LEVEL=info

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_STRING
# Sliding idle-session window for users (extends on activity, expires when idle)
JWT_EXPIRES_IN=30m

# Agent Authentication
AGENT_STATIC_TOKEN=CHANGE_THIS_TO_STRONG_RANDOM_STRING
AGENT_JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_STRING

# Agent Configuration
AGENT_REQUEST_TIMEOUT=300000
AGENT_HEALTH_CHECK_INTERVAL=60000

# Scheduler
MAX_CONCURRENT_BACKUPS=20

# SSL/TLS Configuration - Enable for direct HTTPS/WSS
# If using nginx proxy, keep SSL_ENABLED=false and let nginx handle SSL
SSL_ENABLED=true
SSL_CERT_PATH=/opt/devops/cert/certificate.crt
SSL_KEY_PATH=/opt/devops/cert/privateKey.pem

# Rocket.Chat Integration (optional)
ROCKETCHAT_ENABLED=false
